# =====================================================================
# 시크릿 인벤토리: docs/architecture/security.md#시크릿-인벤토리
# 사용법: 이 파일을 .env로 복사 후 placeholder를 실제 값으로
#   cp .env.example .env
# 랜덤 시크릿 생성:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# =====================================================================

# ─── Postgres (docker-compose) ─────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=summer_star_company

# ─── Backend (FastAPI) ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:changeme@localhost:5440/summer_star_company
JWT_SECRET=changeme-please-generate-32-bytes
AGENT_API_KEY=changeme-please-generate-32-bytes
CORS_ORIGINS=http://localhost:3000

# 등록용 리더(#2) - 백엔드가 직접 제어
READER_NAME=ACR122U
READER_TIMEOUT_SEC=30

# ─── NFC Agent (Pi) ────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000
HTTP_TIMEOUT_SEC=5
LOG_LEVEL=INFO

# ─── Admin Web (Next.js) ───────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
